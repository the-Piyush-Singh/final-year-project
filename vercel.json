{
  "version": 2,
  "builds": [
    {
      "src": "Backend/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "Frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "Backend/index.js"
    },
    {
      "src": "/auth/(.*)",
      "dest": "Backend/index.js"
    },
    {
      "src": "/blog/(.*)",
      "dest": "Backend/index.js"
    },
    {
      "src": "/dashboard/(.*)",
      "dest": "Backend/index.js"
    },
    {
      "src": "/comment/(.*)",
      "dest": "Backend/index.js"
    },
    {
      "src": "/users/(.*)",
      "dest": "Backend/index.js"
    },
    {
      "src": "/feed/(.*)",
      "dest": "Backend/index.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "Frontend/dist/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "Frontend/$1",
      "check": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "Frontend/index.html"
    }
  ]
}
